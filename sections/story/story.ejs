<!-- ========== OUR STORY SECTION ========== -->
<section id="story" class="section section-alt">
  <div class="container">
    <div class="two-column">
      <div class="column story-media story-grid-animate">
        <div class="image-grid">
          <img src="/img/rectangle-96740.png" alt="Luxury experience 1" class="grid-img-1">
          <img src="/img/rectangle-96750.png" alt="Luxury experience 2" class="grid-img-2">
          <img src="/img/rectangle-96760.png" alt="Luxury experience 3" class="grid-img-3">
        </div>
      </div>
      <div class="column story-content story-content-animate">
        <span class="eyebrow">Our Story</span>
        <h2>The Journey to Redefine Luxury Living</h2>
        <p>
          Clean Vibez VIP began with a simple idea — to bring elegance, comfort, and
          care under one roof. From luxury catering and private chefs to seamless
          travel and event assistance, we've built a space where every moment feels
          effortlessly premium.
        </p>
        <p>
          It's not just about service — it's about creating experiences that match your vibe.
        </p>
        <div class="cta-buttons story-btn-animate">
          <a href="#" class="btn btn-outline">
            Read Full Story
            <span class="btn-circle">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="7" y1="17" x2="17" y2="7"></line>
                <polyline points="7 7 17 7 17 17"></polyline>
              </svg>
            </span>
          </a>
        </div>
      </div>
    </section>
    <script>
      document.addEventListener('DOMContentLoaded', function() {
        var section = document.getElementById('story');
        var grid = section.querySelector('.story-grid-animate');
        var content = section.querySelector('.story-content-animate');
        var btn = section.querySelector('.story-btn-animate');
        function animateStory() {
          if(grid) grid.classList.add('animate');
          if(content) content.classList.add('animate');
          if(btn) btn.classList.add('animate');
        }
        function resetStory() {
          if(grid) grid.classList.remove('animate');
          if(content) content.classList.remove('animate');
          if(btn) btn.classList.remove('animate');
        }
        if ('IntersectionObserver' in window) {
          var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
              if (entry.isIntersecting) {
                animateStory();
              } else {
                resetStory();
              }
            });
          }, { threshold: 0.2 });
          observer.observe(section);
        } else {
          animateStory();
        }
      });
    </script>
    </div>
  </div>
</section>

 
