    </nav>
    <div class="header-actions desktop-only">
      <button class="search-btn" aria-label="Search">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
      <button class="btn btn-primary header-cta">
        <span>Book Now</span>
        <img src="/img/vector5.svg" alt="Book Now Icon" width="58" height="58">
      </button>
    </div>
    <div class="mobile-header mobile-only">
      <div class="mobile-header-col mobile-header-logo">
        <img src="/img/logo-print-11.png" alt="Clean Vibez VIP" class="brand-logo">
      </div>
      <div class="mobile-header-col mobile-header-actions">
        <span></span><span></span><span></span>
        <span></span><span></span><span></span>
        <span></span><span></span><span></span>

        <button class="mobile-book-circular-btn">
          <img src="/img/vector5.svg" alt="Book Now Icon" width="28" height="28">
        </button>
        <button class="mobile-menu-toggle" aria-label="Toggle menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
