<!-- ========== DESTINATIONS SECTION ========== -->
<section id="destinations" class="section no-top-gap">
  <div class="container">
    <div class="destinations-header-row">
      <div class="destinations-header-left">
        <span class="eyebrow">Destinations</span>
        <div class="destinations-tabs">
          <button class="chip chip-active" data-tab="hotels"><img src="/img/union0.svg" alt="Hotels"
              class="tab-icon"><span>Elite Hotels</span></button>
          <button class="chip" data-tab="cars"><img src="/img/vector2.svg" alt="Cars" class="tab-icon"><span>Luxury
              Cars</span></button>
          <button class="chip" data-tab="chefs"><img src="/img/vector1.svg" alt="Chefs"
              class="tab-icon"><span>Professional Chefs</span></button>
          <button class="chip" data-tab="concierge"><img src="/img/group-15978824000.svg" alt="Concierge"
              class="tab-icon"><span>Concierge</span></button>
        </div>
      </div>
      <div class="destinations-header-right desktop-only">
        <a href="#" class="btn btn-outline destinations-explore-btn">
          Explore More
          <span class="btn-circle">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </span>
        </a>
      </div>
    </div>

    <div class="destinations-grid">
      <!-- Hotels -->
      <article class="destination-card destination-fadein-animate" data-category="hotels">
        <div class="destination-image" style="background-image: url('/img/card0.png')"></div>
        <div class="destination-content">
          <h3>Paris, France</h3>
          <p class="price"><span class="from">From</span> <strong>$190/night</strong></p>
          <p class="desc">Romantic escapes, art, and cafés.</p>
        </div>
      </article>
      <article class="destination-card destination-fadein-animate" data-category="hotels">
        <div class="destination-image" style="background-image: url('/img/product-card-vertical0.png')"></div>
        <div class="destination-content">
          <h3>Santorini, Greece</h3>
          <p class="price"><span class="from">From</span> <strong>$190/night</strong></p>
          <p class="desc">Sunsets, sea views, and serenity.</p>
        </div>
      </article>
      <article class="destination-card destination-fadein-animate" data-category="hotels">
        <div class="destination-image" style="background-image: url('/img/card1.png')"></div>
        <div class="destination-content">
          <h3>Bali, Indonesia</h3>
          <p class="price"><span class="from">From</span> <strong>$190/night</strong></p>
          <p class="desc">Beaches, nature, and calm vibes.</p>
        </div>
      </article>
      <article class="destination-card destination-fadein-animate" data-category="hotels">
        <div class="destination-image" style="background-image: url('/img/card2.png')"></div>
        <div class="destination-content">
          <h3>Kyoto, Japan</h3>
          <p class="price"><span class="from">From</span> <strong>$190/night</strong></p>
          <p class="desc">Cherry blossoms and temples.</p>
        </div>
      </article>
      <!-- Cars -->
      <article class="destination-card destination-fadein-animate" data-category="cars" style="display:none">
        <div class="destination-image" style="background-image: url('/img/car1.png')"></div>
        <div class="destination-content">
          <h3>Rolls Royce Phantom</h3>
          <p class="price"><span class="from">From</span> <strong>$900/day</strong></p>
          <p class="desc">Ultimate luxury ride for special occasions.</p>
        </div>
      </article>
      <article class="destination-card destination-fadein-animate" data-category="cars" style="display:none">
        <div class="destination-image" style="background-image: url('/img/car2.png')"></div>
        <div class="destination-content">
          <h3>Lamborghini Aventador</h3>
          <p class="price"><span class="from">From</span> <strong>$1200/day</strong></p>
          <p class="desc">Speed, style, and pure adrenaline.</p>
        </div>
      </article>
      <!-- Chefs -->
      <article class="destination-card destination-fadein-animate" data-category="chefs" style="display:none">
        <div class="destination-image" style="background-image: url('/img/chef1.png')"></div>
        <div class="destination-content">
          <h3>Chef Pierre</h3>
          <p class="price"><span class="from">From</span> <strong>$400/event</strong></p>
          <p class="desc">French cuisine, Michelin experience.</p>
        </div>
      </article>
      <article class="destination-card destination-fadein-animate" data-category="chefs" style="display:none">
        <div class="destination-image" style="background-image: url('/img/chef2.png')"></div>
        <div class="destination-content">
          <h3>Chef Maria</h3>
          <p class="price"><span class="from">From</span> <strong>$350/event</strong></p>
          <p class="desc">Mediterranean flavors, healthy delights.</p>
        </div>
      </article>
      <!-- Concierge -->
      <article class="destination-card destination-fadein-animate" data-category="concierge" style="display:none">
        <div class="destination-image" style="background-image: url('/img/concierge1.png')"></div>
        <div class="destination-content">
          <h3>VIP Event Planner</h3>
          <p class="price"><span class="from">From</span> <strong>$600/event</strong></p>
          <p class="desc">Flawless events, every detail managed.</p>
        </div>
      </article>
      <article class="destination-card destination-fadein-animate" data-category="concierge" style="display:none">
        <div class="destination-image" style="background-image: url('/img/concierge2.png')"></div>
        <div class="destination-content">
          <h3>Personal Assistant</h3>
          <p class="price"><span class="from">From</span> <strong>$250/day</strong></p>
          <p class="desc">Your needs, handled with care and privacy.</p>
        </div>
      </article>
    </div>

    <div class="destinations-footer mobile-only" style="margin: 30px auto 0 auto;">
      <a href="#" class="btn btn-outline">
        Explore More
        <span class="btn-circle">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="7" y1="17" x2="17" y2="7"></line>
            <polyline points="7 7 17 7 17 17"></polyline>
          </svg>
        </span>
      </a>
    </div>
    <script>
      document.addEventListener('DOMContentLoaded', function () {
        // Fade in cards on scroll
        var grid = document.querySelector('.destinations-grid');
        var cards = grid.querySelectorAll('.destination-fadein-animate');
        function fadeInCards() {
          cards.forEach(function (card, i) {
            setTimeout(function () {
              card.classList.add('animate');
            }, i * 120);
          });
        }
        if ('IntersectionObserver' in window) {
          var observer = new IntersectionObserver(function (entries, observer) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                fadeInCards();
                observer.disconnect();
              }
            });
          }, { threshold: 0.15 });
          observer.observe(grid);
        } else {
          fadeInCards();
        }

        // Tab logic
        var tabs = document.querySelectorAll('.destinations-tabs .chip');
        tabs.forEach(function (tab) {
          tab.addEventListener('click', function () {
            tabs.forEach(function (t) { t.classList.remove('chip-active'); });
            tab.classList.add('chip-active');
            var cat = tab.getAttribute('data-tab');
            cards.forEach(function (card) {
              if (card.getAttribute('data-category') === cat) {
                card.style.display = '';
              } else {
                card.style.display = 'none';
              }
            });
            // Re-trigger fade-in for visible cards
            setTimeout(function () {
              cards.forEach(function (card, i) {
                if (card.style.display !== 'none') {
                  card.classList.remove('animate');
                  setTimeout(function () {
                    card.classList.add('animate');
                  }, i * 120);
                }
              });
            }, 50);
          });
        });
      });
    </script>
  </div>
</section>