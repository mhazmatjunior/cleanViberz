<!-- Mobile Navigation Sidebar -->
<div class="mobile-sidebar-overlay" id="mobileSidebar">
    <div class="mobile-sidebar-dimmer" id="sidebarDimmer"></div>
    <div class="mobile-sidebar-content">
        <div class="sidebar-header">
            <img src="/img/logo-print-11.png" alt="Clean Vibez VIP" class="sidebar-logo">
            <button class="sidebar-close" id="sidebarClose" aria-label="Close menu">&times;</button>
        </div>

        <nav class="sidebar-nav">
            <a href="/" class="sidebar-link"><span>01</span> Home</a>
            <div class="sidebar-link-wrapper">
                <div class="sidebar-link sidebar-dropdown-toggle">
                    <span>02</span> Services <span class="dropdown-chevron">▼</span>
                </div>
                <div class="sidebar-submenu">
                    <a href="/meal-prep" class="submenu-link">Meal Prep</a>
                    <a href="/car-service" class="submenu-link active">Car Book</a>
                    <a href="/our-story" class="submenu-link">Airbnb Stay</a>
                    <a href="#" class="submenu-link">Private Dinner</a>
                    <a href="/consultancy" class="submenu-link">Consultation</a>
                </div>
            </div>
            <a href="/our-story" class="sidebar-link"><span>03</span> Our Story</a>
            <a href="/contact" class="sidebar-link"><span>04</span> Contact Us</a>
        </nav>

        <div class="sidebar-footer">
            <div class="sidebar-contact">
                <p>info@cleanvibezvip.com</p>
                <p>+1 (555) VIP-VIBE</p>
            </div>
            <a href="/car-book" class="btn btn-primary sidebar-cta">Book Your Experience</a>
        </div>
    </div>
</div>

<script>
    window.addEventListener('DOMContentLoaded', function () {
        const header = document.getElementById('header');
        const menuToggle = document.getElementById('menuToggle');
        const sidebarClose = document.getElementById('sidebarClose');
        const mobileSidebar = document.getElementById('mobileSidebar');
        const sidebarDimmer = document.getElementById('sidebarDimmer');
        const sidebarLinks = document.querySelectorAll('.sidebar-link:not(.sidebar-dropdown-toggle)');
        const dropdownToggle = document.querySelector('.sidebar-dropdown-toggle');
        const dropdownWrapper = document.querySelector('.sidebar-link-wrapper');

        header.classList.add('header-loaded');

        const openSidebar = () => {
            mobileSidebar.classList.add('active');
            document.body.style.overflow = 'hidden';
        };

        const closeSidebar = () => {
            mobileSidebar.classList.remove('active');
            document.body.style.overflow = '';
            if (dropdownWrapper) dropdownWrapper.classList.remove('active');
        };

        if (menuToggle) menuToggle.addEventListener('click', openSidebar);
        if (sidebarClose) sidebarClose.addEventListener('click', closeSidebar);
        if (sidebarDimmer) sidebarDimmer.addEventListener('click', closeSidebar);

        sidebarLinks.forEach(link => {
            link.addEventListener('click', closeSidebar);
        });

        if (dropdownToggle) {
            dropdownToggle.addEventListener('click', function (e) {
                e.stopPropagation();
                dropdownWrapper.classList.toggle('active');
            });
        }
    });
</script>