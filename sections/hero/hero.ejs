<!-- ========== HERO SECTION ========== -->
<section id="hero" class="section hero">
  <div class="hero-bg">
    <img src="/img/joshua-ferrer-2-wl-vu-7-bq-ua-a-unsplash0.png" alt="Luxury dining experience">
  </div>
  <div class="container hero-content">
    <h1 class="hero-title hero-animate-text">Luxury. Comfort. Experience All in One Vibe</h1>
    <p class="hero-subtitle hero-animate-text">
      Whether it's a private dinner, grand event, or a night to remember.
      Clean Vibez VIP brings class, flavor, and comfort to every experience
    </p>
  </div>

  <!-- ========== BOOKING FORM (OVER HERO) ========== -->
  <div class="container hero-booking hero-booking-animate">
    <div class="booking-widget">
      <div class="booking-tabs">
        <button class="chip chip-active">Hotel</button>
        <button class="chip">Car/Van</button>
        <button class="chip">Concierge</button>
        <button class="chip">Chef</button>
      </div>
      <form class="booking-form">
        <div class="form-group">
          <label>Location</label>
          <input type="text" placeholder="Where are you going?">
        </div>
        <div class="form-divider"></div>
        <div class="form-group">
          <label>Check In</label>
          <input type="text" placeholder="Add Dates">
        </div>
        <div class="form-divider"></div>
        <div class="form-group">
          <label>Check Out</label>
          <input type="text" placeholder="Add Dates">
        </div>
        <div class="form-divider"></div>
        <div class="form-group">
          <label>Rooms and Guests</label>
          <input type="text" placeholder="1 Rooms,  2 Adults">
        </div>
        <button type="submit" class="btn-submit-circle">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>