<!-- ========== VIBE SECTION ========== -->
<section id="vibe" class="section vibe-section">
  <div class="vibe-container">
    <div class="vibe-header text-center">
      <h2>Catch the Vibe — Live, Raw &amp; Real</h2>
      <div class="vibe-tabs">
        <button class="chip chip-active">Vlogging</button>
        <button class="chip">Videos</button>
        <button class="chip">Airbnb Hotels</button>
        <button class="chip">Luxury Cars</button>
      </div>
    </div>

    <div class="vibe-media vibe-animate">
      <script>
        document.addEventListener('DOMContentLoaded', function () {
          var section = document.getElementById('vibe');
          var media = section.querySelector('.vibe-animate');
          function animateVibe() {
            media.classList.add('animate');
          }
          function resetVibe() {
            media.classList.remove('animate');
          }
          if ('IntersectionObserver' in window) {
            var observer = new IntersectionObserver(function (entries) {
              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  animateVibe();
                } else {
                  resetVibe();
                }
              });
            }, { threshold: 0.2 });
            observer.observe(section);
          } else {
            animateVibe();
          }
        });
      </script>
      <div class="vibe-video-wrapper">
        <img src="/img/image-10.png" alt="Luxury food experience" id="vibe-thumbnail" style="display:block;">
        <img src="/img/ic_play.svg" alt="Play" id="vibe-play-btn"
          style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:80px;height:80px;cursor:pointer;z-index:2;">
        <video id="vibe-video" style="display:none;width:100%;border-radius:20px;" controls>
          <source src="https://www.w3schools.com/html/mov_bbb.mp4" type="video/mp4">
          Your browser does not support the video tag.
        </video>
      </div>
    </div>
  </div>
</section>
<script>
  const playBtn = document.getElementById('vibe-play-btn');
  const video = document.getElementById('vibe-video');
  const thumb = document.getElementById('vibe-thumbnail');
  playBtn.addEventListener('click', function () {
    playBtn.style.display = 'none';
    thumb.style.display = 'none';
    video.style.display = 'block';
    video.play();
  });
</script>