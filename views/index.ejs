<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Jost:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/vars.css">
  <link rel="stylesheet" href="/css/style.css">
  <!-- Section-specific stylesheets -->
  <link rel="stylesheet" href="/header/header.css">
  <link rel="stylesheet" href="/hero/hero.css">
  <link rel="stylesheet" href="/services/services.css">
  <link rel="stylesheet" href="/story/story.css">
  <link rel="stylesheet" href="/destinations/destinations.css">
  <link rel="stylesheet" href="/booking-cta/booking-cta.css">
  <link rel="stylesheet" href="/why-us/why-us.css">
  <link rel="stylesheet" href="/vibe/vibe.css">
  <link rel="stylesheet" href="/faq/faq.css">
  <link rel="stylesheet" href="/testimonials/testimonials.css">
  <link rel="stylesheet" href="/footer/footer.css">
  <link rel="stylesheet" href="/css/booking-widget.css">
  <script src="/faq.js" defer></script>
  <!-- Google Material Icons -->
  <link href="https://fonts.googleapis.com/icon?family=Material+Icons" rel="stylesheet">
</head>

<body>
  <!-- ========== HEADER ========== -->
  <%- include('../sections/header/header'); %>

  <main>
    <!-- ========== HERO SECTION ========== -->
    <%- include('../sections/hero/hero'); %>

    <!-- ========== SERVICES SECTION ========== -->
    <%- include('../sections/services/services'); %>

    <!-- ========== OUR STORY SECTION ========== -->
    <%- include('../sections/story/story'); %>
    <div class="divider-line-between-sections">
      <img src="/img/divider_line.svg" alt="divider line" class="divider-line-img flipped">
    </div>

    <!-- ========== DESTINATIONS SECTION ==========
    <%- include('../sections/destinations/destinations'); %>

    <!-- ========== BOOKING CTA SECTION ========== -->
    <%- include('../sections/booking-cta/booking-cta'); %>

    <!-- ========== VIBE / MEDIA SECTION ========== -->
    <%- include('../sections/vibe/vibe'); %>
    <!-- ========== WHY CHOOSE US SECTION ========== -->
    <%- include('../sections/why-us/why-us'); %>




    <!-- ========== TESTIMONIALS SECTION ========== -->
    <%- include('../sections/testimonials/testimonials'); %> 

        <!-- ========== FAQ SECTION ========== -->
    <%- include('../sections/faq/faq'); %>
  </main>

  <!-- ========== FOOTER ========== -->
  <%- include('../sections/footer/footer'); %>
</body>

</html>
