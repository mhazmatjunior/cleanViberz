  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Services section animation (already present)
      var section = document.getElementById('services');
      var content = section.querySelector('.services-content-animate');
      var cards = section.querySelectorAll('.service-card-animate');
      var divider = section.querySelector('.divider-fadein-animate');
      function animateServices() {
        content.classList.add('animate');
        cards.forEach(function(card) {
          card.classList.add('animate');
        });
        if(divider) divider.classList.add('animate');
      }
      function resetServices() {
        content.classList.remove('animate');
        cards.forEach(function(card) {
          card.classList.remove('animate');
        });
        if(divider) divider.classList.remove('animate');
      }
      if ('IntersectionObserver' in window) {
        var observer = new IntersectionObserver(function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting) {
              animateServices();
            } else {
              resetServices();
            }
          });
        }, { threshold: 0.2 });
        observer.observe(section);
      } else {
        animateServices();
      }
    });
  </script>
